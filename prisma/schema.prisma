generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  ACTIVE
  SOLD_PENDING_DELETE
  SOLD_CONFIRMED
  DELETED
}

enum MpRole {
  MAKER
  MODEL
  MODEL_DETAIL
  GRADE
  GRADE_DETAIL
}

enum MakerGroup {
  DOMESTIC
  IMPORT
}

model MpNode {
  code String @id

  role MpRole
  name String?
  yearLabel String?
  releaseYear Int?

  makerGroup MakerGroup?

  parentCode String?
  parent     MpNode? @relation("MpNodeParent", fields: [parentCode], references: [code])
  children   MpNode[] @relation("MpNodeParent")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([parentCode])
  @@index([makerGroup])
}

model Listing {
  id Int @id @default(autoincrement())

  source          String  @default("MPARK")
  sourceListingId String  @unique

  makerCode       String
  modelCode       String
  modelDetailCode String
  gradeCode       String?
  gradeDetailCode String?

  // ✅ 표시용 캐시(최소 3개만)
  modelDetailDisplay  String? // "더 올뉴G80 (20~23년)"
  gradeDisplay        String? // "2.5T AWD"
  gradeDetailDisplay  String? // "기본형"

  plateNo    String?
  vin        String?
  vehicleKey String?

  yymm String?
  km   Int?
  price Int?

  fuelCode         String?
  transmissionCode String?
  colorCode        String?

  fuel         MpFuel?         @relation(fields: [fuelCode], references: [code])
  transmission MpTransmission? @relation(fields: [transmissionCode], references: [code])
  color        MpColor?        @relation(fields: [colorCode], references: [code])

  url String?

  status        ListingStatus @default(ACTIVE)
  firstSeenAt   DateTime      @default(now())
  lastSeenAt    DateTime      @default(now())
  soldPendingAt DateTime?
  deletedAt     DateTime?

  mySale MySale?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([makerCode])
  @@index([modelCode])
  @@index([modelDetailCode])

  @@index([makerCode, modelCode, modelDetailCode])
  @@index([gradeCode])
  @@index([gradeDetailCode])

  @@index([fuelCode])
  @@index([transmissionCode])
  @@index([colorCode])

  @@index([vehicleKey])
  @@index([plateNo])
  @@index([price])
  @@index([yymm])
  @@index([km])
  @@index([status, lastSeenAt])
}

model MpColor {
  code    String @id // "006048"
  name    String
  rgbCode String?
  listings Listing[]
}

model MpFuel {
  code String @id // "005001"
  name String
  listings Listing[]
}

model MpTransmission {
  code String @id // "004001"
  name String
  listings Listing[]
}


model MySale {
  id        Int     @id @default(autoincrement())
  listingId Int     @unique
  listing   Listing @relation(fields: [listingId], references: [id])

  soldAt    DateTime @default(now())
  soldPrice Int?
  memo      String?
}